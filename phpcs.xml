<?xml version="1.0"?>
<ruleset name="WooCommerce Stancer Gateway">
    <description>PHPCS rules for WooCommerce Stancer Gateway.</description>

    <file>woocommerce-stancer-gateway.php</file>
    <file>includes</file>
    <file>tests</file>

    <arg name="basepath" value="."/>
    <arg name="colors"/>

    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="PHPCompatibility">
        <properties>
            <property name="testVersion" value="8.1-"/>
        </properties>
    </rule>

    <exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
